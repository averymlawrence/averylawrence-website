---
interface Props {
	text: string;
	href?: string;
}
const { text, href } = Astro.props;
const Tag = href ? 'a' : 'div';
const repeated = Array.from({ length: 40 }, () => text).join(' · ');
---

<Tag class="aw-marquee-wrap" {...(href ? { href } : {})}>
	<div class="aw-marquee-track">
		<span class="aw-marquee-item">{repeated}</span>
		<span class="aw-marquee-item">{repeated}</span>
	</div>
</Tag>

<style>
	.aw-marquee-wrap {
		display: flex;
		overflow: hidden;
		background: var(--color-black);
		height: var(--marquee-height-desktop);
		align-items: center;
		text-decoration: none;
	}

	.aw-marquee-track {
		display: flex;
		white-space: nowrap;
		animation: marqueeScroll 130s linear infinite;
	}

	.aw-marquee-wrap:hover .aw-marquee-track {
		animation-play-state: paused;
	}

	.aw-marquee-item {
		font-family: var(--font-heading);
		font-weight: 500;
		font-size: 34px;
		color: var(--color-white);
		letter-spacing: 1px;
		padding: 0 18px;
		transition: color 0.15s ease;
	}

	.aw-marquee-wrap:hover .aw-marquee-item {
		color: var(--highlight);
	}

	@keyframes marqueeScroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	@media (max-width: 600px) {
		.aw-marquee-wrap {
			height: var(--marquee-height-mobile);
		}

		.aw-marquee-item {
			font-size: 24px;
		}
	}
</style>
