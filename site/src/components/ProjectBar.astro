---
interface Props {
	title: string;
	href: string;
	color: string;
	tags: string[];
	status: 'ready' | 'coming-soon';
}
const { title, href, color, tags, status } = Astro.props;
const label = status === 'coming-soon' ? 'soon' : tags[0];
---

<a
	href={href}
	class="project-bar"
	style={`background-color: ${color}`}
	data-tags={tags.join(',')}
>
	<span class="project-bar-spacer"></span>
	<span class="project-bar-title">{title}</span>
	<span class="project-bar-tag">{label}</span>
</a>

<style>
	.project-bar {
		flex: none;
		height: var(--bar-height-desktop);
		display: flex;
		align-items: center;
		text-decoration: none;
		padding: 0 16px;
		position: relative;
	}

	.project-bar-spacer {
		width: 44px;
	}

	.project-bar-title {
		flex: 1;
		text-align: center;
		font-family: var(--font-heading);
		font-weight: 500;
		font-size: 34px;
		color: var(--color-black);
		transition: color 0.15s ease;
	}

	.project-bar-tag {
		position: absolute;
		right: 16px;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 10px;
		color: rgb(0 0 0 / 50%);
		text-transform: uppercase;
		transition: color 0.15s ease;
	}

	.project-bar:hover {
		background: var(--color-black) !important;
	}

	.project-bar:hover .project-bar-title,
	.project-bar:hover .project-bar-tag {
		color: var(--highlight);
	}

	@media (max-width: 600px) {
		.project-bar {
			height: var(--bar-height-mobile);
			padding: 0 12px;
		}

		.project-bar-title {
			font-size: 24px;
		}

		.project-bar-tag {
			display: none;
		}

		.project-bar-spacer {
			display: none;
		}
	}
</style>
