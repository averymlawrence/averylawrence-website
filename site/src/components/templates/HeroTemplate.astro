---
import { Image } from 'astro:assets';

interface ImageEntry {
	src: ImageMetadata;
	alt: string;
	caption: string;
}

interface Props {
	body?: string;
	video?: string;
	images: ImageEntry[];
}
const { body, video, images } = Astro.props;

const heroImage = video ? undefined : images[0];
const restImages = video ? images : images.slice(1);
---

<div class="hero-template">
	<div class="hero-media">
		{
			video ? (
				<video src={video} controls playsinline />
			) : (
				heroImage && <Image src={heroImage.src} alt={heroImage.alt} />
			)
		}
	</div>
	{body && <p class="body-copy">{body}</p>}
	{
		restImages.length > 0 && (
			<div class="support-grid">
				{restImages.map((img) => (
					<figure>
						<Image src={img.src} alt={img.alt} />
						<figcaption>{img.caption}</figcaption>
					</figure>
				))}
			</div>
		)
	}
</div>

<style>
	.hero-template {
		padding-bottom: 60px;
	}

	.hero-media {
		width: 100%;
		aspect-ratio: 16 / 9;
		background: #000;
	}

	.hero-media video,
	.hero-media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: contain;
		display: block;
	}

	.body-copy {
		max-width: 460px;
		margin: 32px auto;
		padding: 0 16px;
		font-family: var(--font-body);
		font-size: 15px;
		line-height: 1.6;
		text-align: center;
	}

	.support-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 24px;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 16px;
	}

	.support-grid figure {
		margin: 0;
	}

	.support-grid :global(img) {
		width: 100%;
		height: auto;
		display: block;
	}

	.support-grid figcaption {
		font-family: var(--font-body);
		font-size: 13.5px;
		color: #333;
		margin-top: 8px;
		line-height: 1.5;
	}

	@media (max-width: 600px) {
		.support-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
