---
import BaseHead from '../layouts/BaseHead.astro';
---

<html lang="en">
	<head>
		<BaseHead title="averylawrence.com" />
	</head>
	<body>
		<div class="splash">
			<p class="welcome">welcome to averylawrence.com</p>
			<h1 class="headline">are you my grandmother?</h1>
			<div class="buttons">
				<a href="/grandmother" class="btn btn-yes">YES</a>
				<a href="/home" class="btn btn-no">NO</a>
			</div>
			<a href="/home" class="skip">skip splash →</a>
		</div>
	</body>
</html>

<style is:global>
	html,
	body {
		height: 100%;
	}
</style>

<style>
	.splash {
		height: 100dvh;
		background: #111111;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		position: relative;
		padding: 40px;
		box-sizing: border-box;
	}

	.welcome {
		position: absolute;
		top: 26px;
		left: 0;
		right: 0;
		text-align: center;
		font-family: var(--font-body);
		font-size: 13px;
		font-weight: 500;
		color: rgb(255 255 255 / 35%);
		letter-spacing: 0.3px;
		margin: 0;
	}

	.headline {
		font-family: var(--font-heading);
		font-weight: 800;
		font-size: 36px;
		color: var(--color-white);
		text-align: center;
		line-height: 1.2;
		max-width: 600px;
		margin: 0 0 24px;
	}

	.buttons {
		display: flex;
		gap: 16px;
	}

	.btn {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: 16px;
		padding: 12px 32px;
		border-radius: var(--radius-sm);
		text-decoration: none;
	}

	.btn-yes {
		background: var(--color-white);
		color: var(--color-black);
	}

	.btn-no {
		background: transparent;
		color: var(--color-white);
		border: 2px solid var(--color-white);
	}

	.skip {
		position: absolute;
		bottom: 22px;
		right: 26px;
		font-family: var(--font-body);
		font-size: 12px;
		color: rgb(255 255 255 / 45%);
		text-decoration: none;
	}
</style>
