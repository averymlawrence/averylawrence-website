---
import { getCollection } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import ProjectBody from '../../components/ProjectBody.astro';
import { projectColor, projectColorTint } from '../../lib/colors';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { title, order, tags, status, hue, overview, credits, body, video, images } = project.data;
const color = projectColor(order, hue);
const tint = projectColorTint(order, hue);
---

<ProjectLayout title={title} color={color} tag={tags[0]}>
	{
		status === 'coming-soon' ? (
			<div class="coming-soon">
				<p>More on this project soon.</p>
			</div>
		) : (
			<ProjectBody
				overview={overview}
				credits={credits}
				tags={tags}
				video={video}
				body={body}
				images={images}
				tintColor={tint}
			/>
		)
	}
</ProjectLayout>

<style>
	.coming-soon {
		padding: 80px 16px;
		text-align: center;
		font-family: var(--font-body);
		font-size: 16px;
		color: #444;
	}
</style>
