---
import { getCollection } from 'astro:content';
import AppShell from '../layouts/AppShell.astro';

const posts = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<AppShell title="news — averylawrence.com">
	<div class="news-list">
		{
			posts.length === 0 ? (
				<p class="empty">No news posts yet.</p>
			) : (
				posts.map((post) => (
					<a class="news-item" href={`/news/${post.id}`}>
						<span class="news-date">
							{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
						</span>
						<span class="news-title">{post.data.title}</span>
					</a>
				))
			)
		}
	</div>
</AppShell>

<style>
	.news-list {
		max-width: 640px;
		margin: 0 auto;
		padding: 24px 20px 60px;
	}

	.empty {
		font-family: var(--font-body);
		font-size: 15px;
		color: #444;
		text-align: center;
		padding: 60px 0;
	}

	.news-item {
		display: block;
		padding: 20px 0;
		border-bottom: 1px solid var(--gray-3);
		text-decoration: none;
	}

	.news-date {
		display: block;
		font-family: var(--font-body);
		font-size: 12.5px;
		color: #666;
		margin-bottom: 4px;
	}

	.news-title {
		display: block;
		font-family: var(--font-heading);
		font-weight: 500;
		font-size: 22px;
		color: var(--color-black);
	}
</style>
